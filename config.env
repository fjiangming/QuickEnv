# =============================================================================
# QuickEnv 全局配置
# =============================================================================

# 时区
TZ="Asia/Shanghai"

# 服务器系统（auto=自动检测，或手动指定: centos/ubuntu/debian）
OS_TYPE="auto"

# Docker 镜像加速（可选，国内服务器建议配置）
# DOCKER_MIRROR="https://mirror.ccs.tencentyun.com"
# DOCKER_MIRROR="https://registry.docker-cn.com"

# ======================== 服务部署目录 ========================
# 保持与旧服务器完全一致的目录结构
DEPLOY_CPA="$HOME/cpa"
DEPLOY_SUB2API="$HOME/sub2api-deploy"
DEPLOY_NEWAPI="$HOME/new-api"
DEPLOY_SYNCTHING="$HOME/syncthing"
DEPLOY_3XUI="/usr/local/x-ui"
DEPLOY_ESHOP="$HOME/eshop"

# ======================== 服务端口 ========================
PORT_NEWAPI=3000
PORT_SUB2API=9000
PORT_CPA=8317
PORT_3XUI_PANEL=54321
PORT_SYNCTHING_UI=8384
PORT_SYNCTHING_SYNC=22000
PORT_SYNCTHING_DISCOVERY=21027
PORT_ESHOP=2000
PORT_ESHOP_PG=2001
PORT_ESHOP_REDIS=2002

# ======================== 域名配置 ========================
DOMAIN_ESHOP="eshop.fjmooo.cn"
ENABLE_ESHOP_HTTPS=false

PORT_NGINX=80

# ======================== 备份配置 ========================
BACKUP_ROOT="$HOME/syncthing/backups"
BACKUP_SCRIPTS="$HOME/syncthing/scripts"
BACKUP_RETENTION_DAYS=7
BACKUP_CRON_SCHEDULE="0 3 * * *"
